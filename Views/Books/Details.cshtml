@model DuAnDauTien.Models.Book

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <div class="row">
        <!-- Cột trái: Hình ảnh sách -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img src="@Model.Image" class="card-img-top" alt="@Model.Title" style="width: 100%; height: auto;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 400px;">
                        <span class="text-muted">Không có ảnh</span>
                    </div>
                }
            </div>
        </div>

        <!-- Cột phải: Thông tin chi tiết -->
        <div class="col-md-8">
            <h1 class="display-6 fw-bold">@Model.Title</h1>

            <div class="mt-3">
                <p class="mb-1"><strong>Nhà cung cấp:</strong> NXB Trẻ</p>
                <p class="mb-1"><strong>Nhà xuất bản:</strong> NXB Trẻ</p>
            </div>

            <!-- Đánh giá sao -->
            <div class="mt-3 d-flex align-items-center">
                <span class="text-warning fs-5">⭐⭐⭐⭐⭐</span>
                <span class="text-muted ms-2">(79 điểm đánh giá)</span>
            </div>

            <!-- Giá và khuyến mãi -->
            <div class="mt-4 p-3 bg-light rounded">
                <div class="d-flex align-items-center">
                    <span class="text-danger fs-2 fw-bold">@Model.Price.ToString("#,0") đ</span>
                    <span class="text-muted text-decoration-line-through ms-3 fs-5">80,000 đ</span>
                    <span class="badge bg-danger ms-3 fs-6">-23%</span>
                </div>
            </div>

            <!-- Thông tin giao hàng -->
            <div class="mt-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                    <span><strong>Thời gian giao hàng</strong></span>
                    <span>Giao hàng đến <a href="#" class="text-decoration-none">Thay đổi</a></span>
                </div>
                <div class="d-flex justify-content-between align-items-center pt-2">
                    <span><strong>Chính sách đối trả</strong></span>
                    <span>Đổi trả sản phẩm trong 30 ngày <a href="#" class="text-decoration-none">Xem thêm</a></span>
                </div>
            </div>

            <!-- Số lượng và nút mua hàng -->
            <div class="mt-4">
                <div class="d-flex align-items-center">
                    <label class="me-3 fw-bold">Số lượng:</label>
                    <div class="d-flex align-items-center">
                        <button class="btn btn-outline-secondary" onclick="decreaseQuantity()">-</button>
                        <input type="number" id="quantity" value="1" min="1" class="form-control text-center mx-2" style="width: 70px;">
                        <button class="btn btn-outline-secondary" onclick="increaseQuantity()">+</button>
                    </div>
                </div>
            </div>

            <!-- Nút Thêm vào giỏ hàng và Mua ngay -->
            <div class="mt-4 d-flex gap-3">
                <button class="btn btn-warning btn-lg flex-fill fw-bold">Thêm vào giỏ hàng</button>
                <button class="btn btn-danger btn-lg flex-fill fw-bold">Mua ngay</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function decreaseQuantity() {
            var qty = document.getElementById('quantity');
            var val = parseInt(qty.value);
            if (val > 1) {
                qty.value = val - 1;
            }
        }

        function increaseQuantity() {
            var qty = document.getElementById('quantity');
            var val = parseInt(qty.value);
            qty.value = val + 1;
        }
    </script>
}
